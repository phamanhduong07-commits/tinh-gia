# Sao chép file này thành .env ở thư mục GỐC project (cùng chỗ với run.py)
# Nếu không tạo .env, hệ thống tự dùng SQLite (file tinh_gia.db) — OK cho máy đơn

# --- SQLite (mặc định, không cần cài gì thêm) ---
# DATABASE_URL=sqlite:///./tinh_gia.db

# --- PostgreSQL (dùng khi host online cho nhiều người) ---
# DATABASE_URL=postgresql://username:password@localhost:5432/tinh_gia_db

SECRET_KEY=doi-chuoi-nay-thanh-chuoi-ngau-nhien-khi-deploy-len-mang
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://ten-mien-cua-ban.com
